{
  "name": "smartcollar-server",
  "version": "0.1.0",
  "description": "SmartCollar API server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
