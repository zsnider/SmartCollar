    "@fastify/jwt": "^8.0.1",
    "@fastify/websocket": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
